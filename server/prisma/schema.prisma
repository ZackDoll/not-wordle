generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  username     String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  results      DailyResult[]
}

model DailyResult {
  id        String   @id @default(cuid())
  userId    String
  date      String   // 'YYYY-MM-DD'
  guesses   Int
  solved    Boolean
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}
